{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run CellPyAbility Script",
      "type": "shell",
      "command": "/Users/sophienguyen/Documents/cellpy_env312/bin/python",
      "args": ["${workspaceFolder}/${input:scriptName}"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always"
